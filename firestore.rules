rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidBrand(data) {
      return data.keys().hasAll(['id', 'name', 'prefix', 'createdBy']) &&
             data.id is number &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 150 &&
             data.prefix is string && data.prefix.size() >= 3 && data.prefix.size() <= 12 &&
             data.createdBy is string && data.createdBy.size() > 0 && data.createdBy.size() <= 100;
    }
    
    function isValidEan(data) {
      return data.keys().hasAll(['ean', 'brand_id', 'status']) &&
             data.ean is string && data.ean.size() == 13 &&
             data.brand_id is number &&
             data.status in ['generated', 'used', 'blacklisted'];
    }

    match /brands/{brandId} {
      allow read: if true;
      // Permitimos update con los mismos datos por si hay doble clic accidental al crear
      allow create, update: if isValidBrand(request.resource.data);
      allow delete: if false;
    }

    match /eans/{eanId} {
      allow read: if true;
      allow create: if isValidEan(request.resource.data);
      allow update: if isValidEan(request.resource.data) &&
                    request.resource.data.ean == resource.data.ean &&
                    request.resource.data.brand_id == resource.data.brand_id;
      allow delete: if true;
    }
  }
}
